<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions 
    xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" 
    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" 
    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" 
    xmlns:camunda="http://camunda.org/schema/1.0/bpmn" 
    xmlns:di="http://www.omg.org/spec/DD/20100524/DI" 
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
    xmlns:modeler="http://camunda.org/schema/modeler/1.0" 
    id="Definitions_1ntgj7m" 
    targetNamespace="http://bpmn.io/schema/bpmn" 
    exporter="Camunda Modeler" 
    exporterVersion="4.10.0" 
    modeler:executionPlatform="Camunda Platform" 
    modeler:executionPlatformVersion="7.15.0">
  <bpmn:process id="duck_process" isExecutable="true">

    <!-- Начало процесса -->
    <bpmn:startEvent id="start">
      <bpmn:outgoing>flow_start_to_interview</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- Переход: начало → интервью -->
    <bpmn:sequenceFlow id="flow_start_to_interview" sourceRef="start" targetRef="interview_client" />

    <!-- Задача: опрос клиента (ручная, с формой) -->
    <bpmn:userTask id="interview_client" name="Interview Client" camunda:formKey="duck_application">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="variety" label="What is your favorite kind of duck?" type="enum">
            <camunda:value id="Mallard" name="Mallard" />
            <camunda:value id="Wood_Duck" name="Wood Duck" />
            <camunda:value id="Widgeon" name="Widgeon" />
            <camunda:value id="Dead" name="Dead ducks" />
          </camunda:formField>
          <camunda:formField id="tolerant" label="I don&#39;t mind finding feathers and eggs in my home." type="boolean" />
          <camunda:formField id="quantity" label="How many ducks do you want?" type="long" />
        </camunda:formData>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_start_to_interview</bpmn:incoming>
      <bpmn:outgoing>flow_interview_to_determine</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Переход: интервью → определение пригодности -->
    <bpmn:sequenceFlow id="flow_interview_to_determine" sourceRef="interview_client" targetRef="determine_worthiness" />

    <!-- Задача: определить, можно ли доставить настоящую утку (автоматическая, скрипт) -->
    <bpmn:scriptTask id="determine_worthiness" name="Determine Duck Worthiness">
      <bpmn:incoming>flow_interview_to_determine</bpmn:incoming>
      <bpmn:outgoing>flow_determine_to_check</bpmn:outgoing>
      <bpmn:script>if not tolerant or variety == 'Dead' or quantity > 5:
    is_safe = False
else:
    is_safe = True
</bpmn:script>
    </bpmn:scriptTask>

    <!-- Переход: определение → проверка безопасности -->
    <bpmn:sequenceFlow id="flow_determine_to_check" sourceRef="determine_worthiness" targetRef="check_safety" />

    <!-- Развилка: безопасно ли доставлять настоящую утку? -->
    <bpmn:exclusiveGateway id="check_safety" name="will real duck be safe?">
      <bpmn:incoming>flow_determine_to_check</bpmn:incoming>
      <bpmn:outgoing>flow_safe_to_real</bpmn:outgoing>
      <bpmn:outgoing>flow_unsafe_to_decoy</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Переход: безопасно → доставка настоящей утки -->
    <bpmn:sequenceFlow id="flow_safe_to_real" name="is_safe == True" sourceRef="check_safety" targetRef="deliver_real_duck">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">is_safe == True</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <!-- Переход: небезопасно → доставка муляжа -->
    <bpmn:sequenceFlow id="flow_unsafe_to_decoy" name="is_safe == False" sourceRef="check_safety" targetRef="deliver_decoy">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">is_safe == False</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <!-- Задача: доставить настоящую утку (автоматическая) -->
    <bpmn:scriptTask id="deliver_real_duck" name="Deliver real Duck">
      <bpmn:incoming>flow_safe_to_real</bpmn:incoming>
      <bpmn:outgoing>flow_real_to_end</bpmn:outgoing>
      <bpmn:script>print("Delivering a Real Duck!")</bpmn:script>
    </bpmn:scriptTask>

    <!-- Переход: доставка настоящей → конец (ветка настоящей) -->
    <bpmn:sequenceFlow id="flow_real_to_end" sourceRef="deliver_real_duck" targetRef="end_real" />

    <!-- Конец: процесс завершен, настоящая утка доставлена -->
    <bpmn:endEvent id="end_real">
      <bpmn:incoming>flow_real_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Задача: доставить муляж (автоматическая) -->
    <bpmn:scriptTask id="deliver_decoy" name="Deliver Decoy Duck">
      <bpmn:incoming>flow_unsafe_to_decoy</bpmn:incoming>
      <bpmn:outgoing>flow_decoy_to_end</bpmn:outgoing>
      <bpmn:script>print("Just Delivering a Decoy Duck, you can't kill it!")</bpmn:script>
    </bpmn:scriptTask>

    <!-- Переход: доставка муляжа → конец (ветка муляжа) -->
    <bpmn:sequenceFlow id="flow_decoy_to_end" sourceRef="deliver_decoy" targetRef="end_decoy" />

    <!-- Конец: процесс завершен, муляж доставлен -->
    <bpmn:endEvent id="end_decoy">
      <bpmn:incoming>flow_decoy_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Аннотация: пояснение к началу процесса -->
    <bpmn:textAnnotation id="annotation_receive_request">
      <bpmn:text>Receive Request for Duck</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="association_start_to_annotation" sourceRef="start" targetRef="annotation_receive_request" />

  </bpmn:process>

  <!-- Диаграмма (визуальное расположение элементов) -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="duck_process">
      <bpmndi:BPMNShape id="annotation_receive_request_di" bpmnElement="annotation_receive_request">
        <dc:Bounds x="250" y="80" width="100" height="54" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="flow_real_to_end_di" bpmnElement="flow_real_to_end">
        <di:waypoint x="750" y="150" />
        <di:waypoint x="832" y="150" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_interview_to_determine_di" bpmnElement="flow_interview_to_determine">
        <di:waypoint x="330" y="210" />
        <di:waypoint x="370" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_start_to_interview_di" bpmnElement="flow_start_to_interview">
        <di:waypoint x="188" y="210" />
        <di:waypoint x="230" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_safe_to_real_di" bpmnElement="flow_safe_to_real">
        <di:waypoint x="540" y="185" />
        <di:waypoint x="540" y="150" />
        <di:waypoint x="650" y="150" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="552" y="133" width="77" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_unsafe_to_decoy_di" bpmnElement="flow_unsafe_to_decoy">
        <di:waypoint x="540" y="235" />
        <di:waypoint x="540" y="280" />
        <di:waypoint x="650" y="280" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="549" y="283" width="81" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_decoy_to_end_di" bpmnElement="flow_decoy_to_end">
        <di:waypoint x="750" y="280" />
        <di:waypoint x="832" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_determine_to_check_di" bpmnElement="flow_determine_to_check">
        <di:waypoint x="470" y="210" />
        <di:waypoint x="515" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="check_safety_di" bpmnElement="check_safety" isMarkerVisible="true">
        <dc:Bounds x="515" y="185" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="575" y="196" width="78" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="deliver_real_duck_di" bpmnElement="deliver_real_duck">
        <dc:Bounds x="650" y="110" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_real_di" bpmnElement="end_real">
        <dc:Bounds x="832" y="132" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="start_di" bpmnElement="start">
        <dc:Bounds x="152" y="192" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="interview_client_di" bpmnElement="interview_client">
        <dc:Bounds x="230" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="determine_worthiness_di" bpmnElement="determine_worthiness">
        <dc:Bounds x="370" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="deliver_decoy_di" bpmnElement="deliver_decoy">
        <dc:Bounds x="650" y="240" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_decoy_di" bpmnElement="end_decoy">
        <dc:Bounds x="832" y="262" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="association_start_to_annotation_di" bpmnElement="association_start_to_annotation">
        <di:waypoint x="184" y="199" />
        <di:waypoint x="262" y="134" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
